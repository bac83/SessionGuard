#!/usr/bin/env sh
set -e

if [ "$1" = "remove" ] || [ "$1" = "deconfigure" ] || [ "$1" = "upgrade" ] || [ "$1" = "failed-upgrade" ]; then
  systemctl stop sessionguard-agent.service >/dev/null 2>&1 || true
fi

if [ "$1" = "remove" ] || [ "$1" = "deconfigure" ]; then
  systemctl disable sessionguard-agent.service >/dev/null 2>&1 || true
fi

exit 0
